{
  "name": "hono-links-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy src/index.ts",
    "db:migrate": "wrangler d1 execute links-db --file=src/db/migrations/001_init.sql",
    "db:migrate:local": "wrangler d1 execute links-db --local --file=src/db/migrations/001_init.sql"
  },
  "dependencies": {
    "hono": "^4.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.57.0"
  }
}
